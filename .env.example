# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://geo.gsally.com

# Admin auth — comma-separated allowlist of admin emails (required for admin login)
ADMIN_EMAIL_ALLOWLIST=shawn@gsally.com

# Optional integrations
# Email (Resend) — used for mockup preview links and assessment follow-up
RESEND_API_KEY=
RESEND_FROM_EMAIL=Grand Strand Ally <onboarding@resend.dev>
RESEND_REPLY_TO=shawn@gsally.com
ADMIN_NOTIFICATION_EMAIL=shawn@gsally.com
REVIEW_BOOKING_URL=
NEXT_PUBLIC_REVIEW_BOOKING_URL=
SENTRY_DSN=
POSTHOG_KEY=
# Required for Vercel cron routes (/api/cron/*). Generate a random string and set in Vercel.
CRON_SECRET=

# OpenAI homepage concept generation (required for AI-tailored mockups in production)
# Server-side only — do NOT use NEXT_PUBLIC_OPENAI_API_KEY
# After adding/changing this in Vercel, redeploy so the serverless runtime picks it up.
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=

# Optional — higher Microlink screenshot limits for mockup “current site” captures
MICROLINK_API_KEY=

# Optional billing provider mapping (provider not wired yet)
BILLING_PRODUCT_MONITOR=
BILLING_PRICE_MONITOR=
BILLING_PRODUCT_GROWTH=
BILLING_PRICE_GROWTH=
BILLING_PRODUCT_MANAGED=
BILLING_PRICE_MANAGED=

# Results / audit automation
AUDIT_AUTO_PUBLISH=true
AUDIT_REVIEW_REQUIRED=false
RESULTS_TOKEN_EXPIRY_DAYS=90

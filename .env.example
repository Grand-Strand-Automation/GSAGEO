SENTRY_DSN=
POSTHOG_KEY=
CRON_SECRET=

# Results / audit automation
AUDIT_AUTO_PUBLISH=true
AUDIT_REVIEW_REQUIRED=false
RESULTS_TOKEN_EXPIRY_DAYS=90
